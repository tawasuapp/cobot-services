{
  "name": "cobot-services-backend",
  "version": "1.0.0",
  "description": "Cobot Services Fleet Management API",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "migrate": "npx sequelize-cli db:migrate",
